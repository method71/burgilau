{
  "$schema": "https://tr.designtokens.org/format/",
  "font": {
    "family": {
      "$type": "fontFamily",
      "$value": ["Inter", "Arial", "sans-serif"],
      "$description": "Primary font stack for the Burgilau landing page."
    }
  },
  "color": {
    "background-page": {
      "$type": "color",
      "$value": "#eef2f6",
      "$description": "Application page background."
    },
    "background-surface": {
      "$type": "color",
      "$value": "#fff",
      "$description": "Default raised or grouped surface background for sections, cards, and controls."
    },
    "background-surface-hover": {
      "$type": "color",
      "$value": "#f8fafc",
      "$description": "Hover background for interactive surfaces."
    },
    "background-surface-selected": {
      "$type": "color",
      "$value": "#f3f5f7",
      "$description": "Selected background for selectable controls."
    },
    "background-accent": {
      "$type": "color",
      "$value": "#25d366",
      "$description": "Primary action and WhatsApp accent background."
    },
    "background-accent-hover": {
      "$type": "color",
      "$value": "#32d76f",
      "$description": "Hover background for primary accent actions."
    },
    "text-primary": {
      "$type": "color",
      "$value": "#111318",
      "$description": "Primary readable text color."
    },
    "text-secondary": {
      "$type": "color",
      "$value": "#667085",
      "$description": "Secondary text color for supporting content."
    },
    "text-inverse": {
      "$type": "color",
      "$value": "#fff",
      "$description": "Text and icon color used on dark or media-backed surfaces."
    },
    "text-on-accent": {
      "$type": "color",
      "$value": "#111318",
      "$description": "Text and icon color used on accent backgrounds."
    },
    "text-on-media": {
      "$type": "color",
      "$value": "rgba(255, 255, 255, 0.8)",
      "$description": "Secondary readable content color over hero media."
    },
    "border-base": {
      "$type": "color",
      "$value": "#e4e7ec",
      "$description": "Default divider and control border color."
    },
    "border-subtle": {
      "$type": "color",
      "$value": "#e3e7ec",
      "$description": "Low-emphasis border for grouped or selectable surfaces."
    },
    "border-hover": {
      "$type": "color",
      "$value": "#aab2bd",
      "$description": "Hover border for interactive controls and selectable surfaces."
    },
    "border-selected": {
      "$type": "color",
      "$value": "#111318",
      "$description": "Selected border for active controls."
    },
    "border-focus": {
      "$type": "color",
      "$value": "#2563eb",
      "$description": "Shared visible keyboard focus indicator color."
    },
    "border-accent": {
      "$type": "color",
      "$value": "#25d366",
      "$description": "Accent border for emphasized interactive states."
    },
    "background-focus": {
      "$type": "color",
      "$value": "#eff6ff",
      "$description": "Low-emphasis focus background for future compound controls."
    },
    "icon-primary": {
      "$type": "color",
      "$value": "#111318",
      "$description": "Primary icon color."
    },
    "icon-muted": {
      "$type": "color",
      "$value": "#98a2b3",
      "$description": "Muted decorative icon color."
    }
  },
  "size": {
    "page-max-width": {
      "$type": "dimension",
      "$value": "620px",
      "$description": "Maximum width for the main page content column."
    }
  },
  "space": {
    "page-gap": {
      "$type": "dimension",
      "$value": "1rem",
      "$description": "Default gap between major page sections."
    },
    "page-inline-padding": {
      "$type": "dimension",
      "$value": "clamp(0.5rem, 3vw, 1.5rem)",
      "$description": "Responsive inline page padding."
    },
    "1": {
      "$type": "dimension",
      "$value": "4px",
      "$description": "Base compact spacing step."
    },
    "2": {
      "$type": "dimension",
      "$value": "8px",
      "$description": "Small spacing step."
    },
    "3": {
      "$type": "dimension",
      "$value": "10px",
      "$description": "Tight control spacing step."
    },
    "4": {
      "$type": "dimension",
      "$value": "12px",
      "$description": "Compact component spacing step."
    },
    "5": {
      "$type": "dimension",
      "$value": "16px",
      "$description": "Default component spacing step."
    },
    "6": {
      "$type": "dimension",
      "$value": "20px",
      "$description": "Medium component spacing step."
    },
    "7": {
      "$type": "dimension",
      "$value": "24px",
      "$description": "Large component spacing step."
    },
    "8": {
      "$type": "dimension",
      "$value": "28px",
      "$description": "Large layout spacing step."
    },
    "9": {
      "$type": "dimension",
      "$value": "32px",
      "$description": "Largest standard layout spacing step."
    }
  },
  "radius": {
    "section": {
      "$type": "dimension",
      "$value": "24px",
      "$description": "Radius for large page sections."
    },
    "card": {
      "$type": "dimension",
      "$value": "20px",
      "$description": "Radius for selectable cards."
    },
    "button": {
      "$type": "dimension",
      "$value": "16px",
      "$description": "Radius for buttons and action controls."
    }
  },
  "motion": {
    "transition-fast": {
      "$type": "duration",
      "$value": "0.15s",
      "$description": "Default short UI transition duration."
    }
  }
}
