{
  "name": "burgilau",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:tokens": "node scripts/design-system-tokens.js build",
    "check:tokens": "node scripts/design-system-tokens.js check",
    "build": "vite build",
    "preview": "vite preview",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint:js": "eslint .",
    "lint:styles": "stylelint \"src/scss/**/*.scss\"",
    "lint": "npm run lint:js && npm run lint:styles",
    "test:unit": "node --test tests/unit",
    "test:e2e": "playwright test",
    "test": "npm run test:unit && npm run test:e2e",
    "check": "npm run format:check && npm run lint && npm test && npm run build"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "prettier": "^3.9.6",
    "sass": "^1.89.2",
    "stylelint": "^17.14.1",
    "stylelint-config-standard-scss": "^17.0.0",
    "vite": "^7.0.5"
  }
}
